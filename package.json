    "swc-loader": "^0.2.3",
    "tailwindcss": "^3.4.3",
    "terser-webpack-plugin": "^5.3.9",
    "typescript": "^5.1.3",
    "vue": "^3.3.4",
    "vue-html-loader": "^1.2.4",
    "vue-loader": "^17.2.2",
    "vue-router": "^4.2.2",
    "vue-style-loader": "^4.1.3",
